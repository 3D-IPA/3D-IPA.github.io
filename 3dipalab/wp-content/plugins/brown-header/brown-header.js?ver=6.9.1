jQuery(document).ready(function($){
    $('<div id="brown-header" class="brown-header"><div id="brown-brand-box"><h2 id="brown-logo"><a href="https://www.brown.edu">Brown University</a></h2></div></div>')
    .prependTo('body');

    var bodyPaddingLeft = $('body').css('padding-left')
    var bodyPaddingRight = $('body').css('padding-right')

    if (bodyPaddingLeft != "0px"){
        $('head').append('<style type="text/css" media="screen">.brown-header{margin-left:-'+bodyPaddingLeft+';padding-left:'+bodyPaddingLeft+';}</style>');
    }
    if (bodyPaddingRight != "0px"){
        $('head').append('<style type="text/css" media="screen">.brown-header{margin-right:-'+bodyPaddingRight+';padding-right:'+bodyPaddingRight+';}</style>');
    }
});
